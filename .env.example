# =============================================================================
# Convoflow AI — Master Environment Reference
#
# HOW TO USE:
#   Backend  → copy to backend/.env  (git-ignored — NEVER commit)
#   Mobile   → copy relevant vars to mobile/.env  (EXPO_PUBLIC_* prefix)
#   Web      → set VITE_API_URL in Vercel environment variables UI
#
# GENERATE SECRET_KEY:
#   python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================

# ─── General ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production
SECRET_KEY=GENERATE_ME           # REQUIRED — min 32 chars random hex
DEBUG=true                       # set false in production

# ─── AI: Transcription — Groq Whisper (PRIMARY) ───────────────────────────────
# Free 14,400 audio-minutes/day. Supports Tamil + English (multilingual).
# Sign up: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_...
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# ─── AI: Intent Extraction — DeepSeek V3 (PRIMARY) ───────────────────────────
# ~$0.27/M input tokens (50x cheaper than GPT-4o). Best for structured extraction.
# Sign up: https://platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_TEMPERATURE=0.1

# ─── AI: Fallback — Vercel AI Gateway ────────────────────────────────────────
# Auto-used if GROQ_API_KEY or DEEPSEEK_API_KEY are empty.
AI_GATEWAY_API_KEY=vck_...
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
AI_GATEWAY_WHISPER_MODEL=whisper-1
AI_GATEWAY_CHAT_MODEL=gpt-4o-mini
AI_GATEWAY_TEMPERATURE=0.1

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev: SQLite (default, no setup needed)
DATABASE_URL=sqlite:///./convoflow.db
# Production (Supabase PostgreSQL — Transaction Pooler URL):
# DATABASE_URL=postgresql://postgres.PROJECTREF:PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ─── Supabase Storage ─────────────────────────────────────────────────────────
# Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJ...      # service_role — backend only, NEVER expose to frontend
SUPABASE_ANON_KEY=eyJ...         # anon key — safe for frontend
SUPABASE_BUCKET=recordings

# ─── Pabbly Connect ───────────────────────────────────────────────────────────
PABBLY_WEBHOOK_URL=https://connect.pabbly.com/workflow/sendwebhookdata/...
PABBLY_SECRET_KEY=your-random-pabbly-secret

# ─── File Storage Fallback ────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_AUDIO_SIZE_MB=100

# ─── JWT / Auth ───────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://convoflow-web.vercel.app

# ─── App Meta ─────────────────────────────────────────────────────────────────
APP_TITLE=Convoflow AI API — EduTech Edition
APP_DESCRIPTION=EduTech sales call transcription and lead automation platform.
APP_VERSION=1.0.0

# ─── Razorpay (Phase 2) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...

# ─── Mobile (Expo — set in mobile/.env) ──────────────────────────────────────
# EXPO_PUBLIC_ prefix makes vars accessible in React Native code.
# Local dev: use your machine's local IP (not localhost — phone can't reach it)
# EXPO_PUBLIC_API_URL=http://192.168.x.x:8000

# ─── Web (Vite — set in Vercel Environment Variables) ────────────────────────
# Leave blank in local dev (Vite proxy handles /api → localhost:8000).
# Set to your EC2 IP or domain for production.
# VITE_API_URL=http://13.205.182.171

