{
  "expo": {
    "name": "Convoflow AI",
    "slug": "convoflow-ai",
    "version": "1.1.0",
    "sdkVersion": "55.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#002147"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.convoflow.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Convoflow AI needs microphone access to record client conversations.",
        "NSSpeechRecognitionUsageDescription": "Convoflow AI uses speech recognition to transcribe conversations."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#002147"
      },
      "package": "com.convoflow.app",
      "permissions": [
        "RECORD_AUDIO",
        "READ_PHONE_STATE",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow Convoflow AI to save lead contacts to your phone."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Convoflow AI needs microphone access to record client conversations.",
          "recordAudioAndroid": true,
          "enableBackgroundRecording": true
        }
      ],
      "expo-web-browser",
      "expo-asset",
      "expo-secure-store"
    ],
    "scheme": "convoflow",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "57dd3fc3-3f55-466a-8905-6820d481763f"
      }
    },
    "owner": "soulz08"
  }
}
