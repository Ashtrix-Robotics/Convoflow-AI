{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "comment": "Dev build — includes DevMenu, connects to local Metro bundler. Install on your phone for testing with Metro.",
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "env": {
          "EXPO_PUBLIC_API_URL": "http://192.168.31.173:8000"
        }
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.31.173:8000"
      }
    },
    "preview": {
      "comment": "Internal APK for sales team testing — standalone, hits production API.",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://convoflow-api.onrender.com"
      }
    },
    "production": {
      "comment": "Production AAB for Google Play Store submission.",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://convoflow-api.onrender.com"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}
