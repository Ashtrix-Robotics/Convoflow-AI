# =============================================================================
# Convoflow AI — Web Dashboard Environment
# Copy to web/.env.local for local overrides (Vite reads .env.local).
# In production (Vercel): set these in the Vercel Environment Variables UI.
# =============================================================================

# API base URL — MUST be set in Vercel for production.
# In local dev: leave this blank (Vite proxy in vite.config.ts handles /api → localhost:8000).
VITE_API_URL=https://convoflow-api.onrender.com

# ── Supabase Auth (optional but recommended) ──────────────────────────────────
# When set, the Login page uses Supabase Auth for sign-in (session management,
# token refresh, future OAuth/magic-link support). Falls back to direct FastAPI
# auth if these are not set.
# Find these in: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>
